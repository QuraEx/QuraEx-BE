# QuraEx v2 — example environment variables
# Copy to .env and fill in real values (never commit .env)

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Per-service Postgres ports (one container per service)
POSTGRES_AUTHORING_PORT=5432
# POSTGRES_IDENTITY_PORT=5433
# POSTGRES_WORKSPACE_PORT=5434

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=changeme
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Redis
REDIS_PORT=6379

# GitHub Packages (read:packages scope — for restoring QuraEx.BuildingBlocks*)
# GITHUB_PACKAGES_TOKEN=REPLACE_ME

# OTel (optional — Aspire Dashboard used in dev, OTLP exporter for prod)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=authoring

# Gateway JWT signing (RS256 — private key NEVER goes in this file)
# GATEWAY_JWT_AUTHORITY=https://localhost:5001
# GATEWAY_JWT_AUDIENCE=quraex-api
