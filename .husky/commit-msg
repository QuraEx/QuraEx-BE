#!/bin/sh
# Enforce Conventional Commits format on commit messages
# Pattern: type(scope): description
# Allowed types: feat|fix|refactor|test|build|ci|perf|revert|style

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Allow merge commits and fixup commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
    exit 0
fi

PATTERN="^(feat|fix|refactor|test|build|ci|perf|revert|style)(\([a-z0-9\-]+\))?: .{1,100}$"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo "❌  Invalid commit message format."
    echo ""
    echo "    Expected: type(scope): description"
    echo "    Example:  feat(authoring): add create user story endpoint"
    echo ""
    echo "    Allowed types: feat | fix | refactor | test | build | ci | perf | revert | style"
    echo "    Note: 'chore' and 'docs' are disallowed per project convention (.claude rules)."
    echo ""
    echo "    Your message: $COMMIT_MSG"
    echo ""
    exit 1
fi
