#!/bin/sh
# Quick build sanity before push — catches broken code before CI sees it
if [ -z "$CI" ]; then
    echo "Running build sanity check before push..."
    dotnet build QuraEx.slnx --nologo -q
    if [ $? -ne 0 ]; then
        echo "❌  Build failed. Fix errors before pushing."
        exit 1
    fi
    echo "✅  Build passed."
fi
