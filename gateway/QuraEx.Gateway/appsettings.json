{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "quraex-gateway",
    "Audience": "quraex-api"
  },
  "RateLimiting": {
    "WindowSeconds": 60,
    "PermitLimit": 100,
    "QueueLimit": 0
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "identity-health-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "workspace-route": {
        "ClusterId": "workspace-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/workspace/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "workspace-health-route": {
        "ClusterId": "workspace-cluster",
        "Match": {
          "Path": "/api/workspace/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      },
      "authoring-route": {
        "ClusterId": "authoring-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/authoring/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/{**catch-all}" }
        ]
      },
      "authoring-health-route": {
        "ClusterId": "authoring-cluster",
        "Match": {
          "Path": "/api/authoring/health"
        },
        "Transforms": [
          { "PathPattern": "/health" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity": {
            "Address": "http://identity"
          }
        }
      },
      "workspace-cluster": {
        "Destinations": {
          "workspace": {
            "Address": "http://workspace"
          }
        }
      },
      "authoring-cluster": {
        "Destinations": {
          "authoring": {
            "Address": "http://authoring"
          }
        }
      }
    }
  }
}
