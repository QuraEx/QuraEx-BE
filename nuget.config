<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- GitHub Packages: token must be set via GITHUB_PACKAGES_TOKEN env var or OS credential store.
         PAT scopes needed: read:packages (local dev), write:packages (CI publish only).
         Never commit a token here — this file is PUBLIC. -->
    <add key="github" value="https://nuget.pkg.github.com/bavanchun/index.json" />
  </packageSources>

  <packageSourceCredentials>
    <github>
      <add key="Username" value="bavanchun" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github>
  </packageSourceCredentials>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="QuraEx.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
