# Production env for the droplet. Copy to deploy/.env on the server and fill in.
# NEVER commit the real .env — it holds DB/broker passwords and the tunnel token.

# Image tag to run (CI sets this to the commit SHA; 'latest' also published).
IMAGE_TAG=latest

# PostgreSQL (containerized, data in named volume)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# RabbitMQ
RABBITMQ_USER=quraex
RABBITMQ_PASSWORD=CHANGE_ME_strong_password

# Cloudflare Tunnel token (from Zero Trust dashboard → Tunnels → your tunnel → token)
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_tunnel_token
