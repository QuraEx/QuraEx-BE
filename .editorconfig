root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{csproj,props,targets,yml,yaml,json,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# C# conventions
[*.cs]
indent_size = 4
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion
dotnet_style_require_accessibility_modifiers = always:error
dotnet_sort_system_directives_first = true
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion

csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_prefer_braces = true:error
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

# Naming rules
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.style = prefix_i_style
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.severity = error
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.prefix_i_style.required_prefix = I
dotnet_naming_style.prefix_i_style.capitalization = pascal_case

dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_case
dotnet_naming_rule.private_fields_underscore.severity = suggestion
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

# StyleCop — downgraded to suggestion for Phase 1-5; tightened to error in Phase 6
# (per plan risk: "keep analyzer ramp pragmatic; tighten in Phase 6")
dotnet_analyzer_diagnostic.category-Style.severity = suggestion
# All SA* rules as suggestions (non-blocking) until Phase 6
dotnet_diagnostic.SA0001.severity = none
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1101.severity = none
dotnet_diagnostic.SA1200.severity = none
dotnet_diagnostic.SA1201.severity = suggestion
dotnet_diagnostic.SA1202.severity = suggestion
dotnet_diagnostic.SA1204.severity = suggestion
dotnet_diagnostic.SA1210.severity = none
dotnet_diagnostic.SA1309.severity = suggestion
dotnet_diagnostic.SA1316.severity = none
dotnet_diagnostic.SA1402.severity = suggestion
dotnet_diagnostic.SA1502.severity = suggestion
dotnet_diagnostic.SA1516.severity = none
# Sonar rules — intentional patterns
dotnet_diagnostic.S3011.severity = none  # Reflection in EF convention helper — intentional
dotnet_diagnostic.S3267.severity = suggestion
dotnet_diagnostic.S2139.severity = suggestion  # log-and-rethrow — logging behavior intentional
dotnet_diagnostic.S1144.severity = suggestion  # Unused private setter — EF needs it
dotnet_diagnostic.SA1208.severity = none  # System-before-Microsoft ordering — conflicts with IDE auto-sort
dotnet_diagnostic.S4136.severity = suggestion  # Method overloads adjacent — readability preference
# SA doc-comment rules — suppressed; we only doc public API where non-obvious
dotnet_diagnostic.SA1604.severity = none
dotnet_diagnostic.SA1611.severity = none
dotnet_diagnostic.SA1612.severity = none
dotnet_diagnostic.SA1615.severity = none
dotnet_diagnostic.SA1618.severity = none
dotnet_diagnostic.SA1623.severity = none
dotnet_diagnostic.SA1616.severity = none
dotnet_diagnostic.SA1649.severity = none  # File name != type name — intentional for extension method files
dotnet_diagnostic.SA1629.severity = none
